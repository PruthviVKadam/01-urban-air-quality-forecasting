# --- Secrets ---
.env
.env.*
!.env.example
*.key

# --- Python (backend / ML) ---
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.ipynb_checkpoints/

# --- Node (frontend) ---
frontend/node_modules/
frontend/dist/
frontend/playwright-report/
frontend/test-results/
node_modules/
dist/
.vite/
*.local

# --- Data (keep folders via .gitkeep, ignore contents) ---
data/raw/*
data/processed/*
data/cache/*
!data/**/.gitkeep

# --- Models & experiment tracking (ship the evidence, not the weights) ---
# The model card + registry (metrics, beats_baseline verdict, training window) are the
# committed proof of gate G2; the multi-megabyte .joblib weights are rebuilt locally by
# `scripts/seed_and_train.py`.
models/*
!models/.gitkeep
!models/MODEL_CARD.md
!models/registry.json
*.joblib
mlruns/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
