# Copy to .env (gitignored) and fill in. The repo runs on documented free tiers.

# --- Runtime ---
APP_ENV=dev
LOG_LEVEL=INFO
# JSON array of allowed CORS origins (Vite dev server by default).
CORS_ORIGINS=["http://localhost:5173"]

# --- Hard-limit knobs (override only with reason) ---
STALE_THRESHOLD_HOURS=3
MAX_HORIZON_HOURS=24

# --- Upstream API keys (Phase 1) ---
# OpenAQ: free key, header auth — https://docs.openaq.org/
OPENAQ_API_KEY=
# AirNow: free key, strict ~500 req/hr — https://docs.airnowapi.org/
AIRNOW_API_KEY=
# Open-Meteo needs NO key (https://open-meteo.com/).
